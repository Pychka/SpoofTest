<UserControl x:Class="SpoofTest.Views.PlaceHolderTextBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SpoofTest.Views"
             mc:Ignorable="d" 
             d:DesignHeight="40" d:DesignWidth="200">
    <Grid>
        <TextBlock x:Name="Place" Foreground="Gray" Text="{Binding PlaceHolder, RelativeSource={RelativeSource AncestorType=UserControl}}" Padding="2 0"/>
        <TextBox Background="Transparent" TextChanged="TextBox_TextChanged" MaxLength="{Binding MaxLetters, RelativeSource={RelativeSource AncestorType=UserControl}}" Text="{Binding Text, UpdateSourceTrigger=PropertyChanged, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
    </Grid>
</UserControl>
