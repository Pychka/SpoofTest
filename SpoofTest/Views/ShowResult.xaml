<Window x:Class="SpoofTest.Views.ShowResult"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SpoofTest.Views"
        mc:Ignorable="d"
        Title="ShowResult" Height="200" WindowStyle="None" Width="400">
    <StackPanel>
        <TextBlock Text="Введите код, чтобы увидеть результат:" Margin="5"/>
        <PasswordBox x:Name="Pass" Height="30" Margin="5"/>
        <Button Content="Show" IsDefault="True" Height="30" Margin="5" Click="Button_Click"/>
    </StackPanel>
</Window>
